{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/tooling/cli/schema.json",
  "productName": "Matrix Notebook",
  "version": "0.1.4",
  "identifier": "com.matrix.notebook",
  "build": {
    "beforeDevCommand": "npm run start:web",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist/matrix-notebook",
    "devUrl": "http://127.0.0.1:4200"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline';"
    },
    "windows": [
      {
        "label": "main",
        "title": "Matrix Notebook",
        "width": 1280,
        "height": 800,
        "visible": false,
        "backgroundColor": "#e2e8f0",
        "resizable": true,
        "minimizable": true,
        "maximizable": true,
        "decorations": false,
        "dragDropEnabled": false,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist"
    }
  }
}